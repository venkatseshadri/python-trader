    "fact_definitions": "orbiter/rules/fact_definitions.json",
    "broker_credentials": "ShoonyaApi-py/cred.yml",
    "constants": "orbiter/config/constants.json",
    "schema": "orbiter/config/schema.json",
    "ghost_position_template": "orbiter/config/ghost_position_template.json",
    "broker_data_mapping": "orbiter/config/broker_data_mapping.json",
    "exchange_config": "orbiter/config/exchange_config.json"
  },
  "optional_files": {
    "global_config": "orbiter/config/global_config.json",
