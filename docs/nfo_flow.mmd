flowchart TB
    subgraph CLI["CLI: python orbiter/main.py"]
        C1["--paper_trade=true"]
        C2["--strategyCode=n1"]
    end

    subgraph STARTUP["Startup: orbiter/main.py"]
        S1["ArgumentParser.parse_cli_to_facts()"]
        S2["Read system.json<br/>→ strategy_codes"]
        S3["Resolve n1 → nifty_fno_topn_trend"]
        S4["OrbiterApp(context)"]
        S5["EngineBuilder.build()"]
    end

    subgraph JSON["JSON Configuration Files"]
        J1["system.json<br/>strategy_codes"]
        J2["strategies/nifty_fno_topn_trend/<br/>instruments.json<br/>(stock symbols)"]
        J3["strategies/nifty_fno_topn_trend/<br/>rules.json<br/>(scoring, strike_logic)"]
        J4["strategies/nifty_fno_topn_trend/<br/>filters.json<br/>(weights)"]
        J5["futures_master.json<br/>(EXISTS ✅)"]
    end

    subgraph SCAN["Phase 1: Scanning (Futures)"]
        A1["For each stock in instruments.json"]
        A2["Get futures from SYMBOLDICT<br/>(from futures_master.json)"]
        A3["FactCalculator.calculate_technical_facts()<br/>ADX, EMA, SuperTrend"]
        A4["RuleManager.evaluate()<br/>Score from rules.json"]
        A5{"Score >=<br/>Threshold?"}
        A5 -->|No| A1
        A5 -->|Yes| TRADE
    end

    subgraph TRADE["Phase 2: Trade Execution (Options)"]
        T1["resolve_option_symbol(symbol, ltp, option_type, strike_logic, expiry_type)"]
        T2["_select_expiry(symbol, expiry_type, instrument)<br/>→ expiry date"]
        T3["_get_option_rows(symbol, ltp, expiry, instrument)"]
        T4{"futures_master.json<br/>has option data?"}
        T4 -->|Yes| T5["Return rows from file"]
        T4 -->|No| T6["_query_broker_options_api()"]
        T6 --> T7["get_security_info(exchange, token)<br/>→ lot_size"]
        T7 --> T8["Generate strikes<br/>around ATM (ltp)"]
        T8 --> T5
        T5 --> T9["Apply strike_logic<br/>ATM → ATM+1"]
        T9 --> T10["Return: token, tradingsymbol,<br/>lot_size, exchange"]
        T10 --> T11["place_spread() → Broker API"]
    end

    CLI --> STARTUP
    STARTUP --> JSON
    JSON --> SCAN
    SCAN --> TRADE

    style CLI fill:#e3f2fd
    style STARTUP fill:#e8f5e9
    style JSON fill:#fff3e0
    style SCAN fill:#fce4ec
    style TRADE fill:#e1f5fe
