{
  "scoring_rules": [
    {
      "name": "Calculate Nifty Trend Score",
      "priority": 10,
      "index_signals": {
        "allOf": [
          { "fact": "instrument.instrument_type", "operator": "equal", "value": "index" }
        ]
      },
      "scoring_expression": "index.adx * filters.scoring.combined_score.weight_adx + (index.ema_fast - index.ema_slow) / index.ema_slow * 100 * filters.scoring.combined_score.weight_ema_slope + index.supertrend_dir * filters.scoring.combined_score.weight_supertrend * 10",
      "description": "Combines ADX strength, EMA slope (momentum), and SuperTrend direction for weekly index trend scoring."
    },
    {
      "name": "Calculate Stock Option Score",
      "priority": 15,
      "index_signals": {
        "allOf": [
          { "fact": "instrument.expiry_cycle", "operator": "equal", "value": "monthly" },
          { "fact": "instrument.instrument_type", "operator": "equal", "value": "stock" },
          { "fact": "instrument.derivative", "operator": "equal", "value": "option" }
        ]
      },
      "scoring_expression": "index.adx * filters.scoring.combined_score.weight_adx + (index.ema_fast - index.ema_slow) / index.ema_slow * 100 * filters.scoring.combined_score.weight_ema_slope + index.supertrend_dir * filters.scoring.combined_score.weight_supertrend * 10",
      "description": "Combines ADX strength, EMA slope, and SuperTrend direction for stock option trend scoring."
    }
  ],
  "strategies": [
    {
      "name": "Nifty_FNO_TopN_Trend_Nifty_Execution",
      "priority": 100,
      "index_signals": {
        "allOf": [
          { "fact": "session.is_trade_window", "operator": "equal", "value": true },
          { "fact": "instrument.has_position", "operator": "equal", "value": false },
          { "fact": "instrument.derivative", "operator": "equal", "value": "option" },
          { "fact": "instrument.symbol", "operator": "equal", "value": "NIFTY" }
        ]
      },
      "execution_logic": "TOP_N",
      "top_n": "strategy.top_n",
      "scoring_fact": "strategy.trend_score",
      "score_threshold": 3.0,
      "order_operations": [
        { 
          "type": "trade.place_spread", 
          "params": { 
            "side": "BUY",
            "strike_logic": "ATM+1",
            "option_type": "CE",
            "expiry_type": "weekly+0"
          } 
        },
        { 
          "type": "trade.place_spread", 
          "params": { 
            "side": "SELL", 
            "strike_logic": "ATM-1",
            "option_type": "PE",
            "expiry_type": "weekly+0"
          } 
        }
      ]
    },
    {
      "name": "Nifty_FNO_TopN_Trend_Index_Execution",
      "priority": 100,
      "index_signals": {
        "allOf": [
          { "fact": "session.is_trade_window", "operator": "equal", "value": true },
          { "fact": "instrument.has_position", "operator": "equal", "value": false },
          { "fact": "instrument.derivative", "operator": "equal", "value": "option" },
          { "fact": "instrument.instrument_type", "operator": "equal", "value": "index" },
          { "fact": "instrument.symbol", "operator": "notEqual", "value": "NIFTY" }
        ]
      },
      "execution_logic": "TOP_N",
      "top_n": "strategy.top_n",
      "scoring_fact": "strategy.trend_score",
      "score_threshold": 3.0,
      "order_operations": [
        { 
          "type": "trade.place_spread", 
          "params": { 
            "side": "BUY",
            "strike_logic": "ATM+1",
            "option_type": "CE",
            "expiry_type": "monthly+0"
          } 
        },
        { 
          "type": "trade.place_spread", 
          "params": { 
            "side": "SELL", 
            "strike_logic": "ATM-1",
            "option_type": "PE",
            "expiry_type": "monthly+0"
          } 
        }
      ]
    },
    {
      "name": "Nifty_FNO_TopN_Trend_Stock_Execution",
      "priority": 100,
      "index_signals": {
        "allOf": [
          { "fact": "session.is_trade_window", "operator": "equal", "value": true },
          { "fact": "instrument.has_position", "operator": "equal", "value": false },
          { "fact": "instrument.derivative", "operator": "equal", "value": "option" },
          { "fact": "instrument.instrument_type", "operator": "equal", "value": "stock" }
        ]
      },
      "execution_logic": "TOP_N",
      "top_n": "strategy.top_n",
      "scoring_fact": "strategy.trend_score",
      "score_threshold": 3.0,
      "order_operations": [
        { 
          "type": "trade.place_spread", 
          "params": { 
            "side": "BUY",
            "strike_logic": "ATM+1",
            "option_type": "CE",
            "expiry_type": "monthly+0"
          } 
        },
        { 
          "type": "trade.place_spread", 
          "params": { 
            "side": "SELL", 
            "strike_logic": "ATM-1",
            "option_type": "PE",
            "expiry_type": "monthly+0"
          } 
        }
      ]
    }
  ]
}
