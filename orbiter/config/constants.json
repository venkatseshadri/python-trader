{
  "weeklyExpiryDays": {
    "NIFTY": "Tuesday",
    "SENSEX": "Thursday",
    "note": "Weekly expiry days unless it's a holiday - then moves to previous trading day. Other indices (BANKNIFTY, FINNIFTY, MIDCPNIFTY) have monthly expiries."
  },
  "eventTypes": {
    "app.setup": {
      "description": "Lifecycle: app initialization (load config, initialize logger, validate credentials)",
      "handlers": [
        {
          "function": "app.load_config",
          "priority": 1,
          "required": true,
          "description": "Load configuration files and validate paths"
        },
        {
          "function": "app.initialize_logger",
          "priority": 2,
          "required": true,
          "description": "Initialize logging system"
        },
        {
          "function": "app.validate_credentials",
          "priority": 3,
          "required": true,
          "description": "Validate broker credentials exist and are valid"
        },
        {
          "function": "app.setup",
          "priority": 4,
          "required": true,
          "description": "Main app setup (broker client init, scrip master download)"
        }
      ]
    },
    "app.login": {
      "description": "Lifecycle: broker authentication and connection verification",
      "handlers": [
        {
          "function": "app.authenticate_broker",
          "priority": 1,
          "required": true,
          "description": "Authenticate with broker API"
        },
        {
          "function": "app.verify_connection",
          "priority": 2,
          "required": true,
          "description": "Verify connection is alive"
        },
        {
          "function": "app.fetch_broker_limits",
          "priority": 3,
          "required": false,
          "description": "Fetch margin/limits from broker"
        },
        {
          "function": "app.login",
          "priority": 4,
          "required": true,
          "description": "Main login handler (app.login or engine.client.login)"
        }
      ]
    },
    "app.prime_data": {
      "description": "Lifecycle: load historical candles and prime data for trading",
      "handlers": [
        {
          "function": "app.load_instrument_masters",
          "priority": 1,
          "required": true,
          "description": "Load NSE/MCX scrip masters"
        },
        {
          "function": "app.build_symbol_mappings",
          "priority": 2,
          "required": true,
          "description": "Build token-to-symbol mappings"
        },
        {
          "function": "app.initialize_margin_calculator",
          "priority": 3,
          "required": true,
          "description": "Initialize span margin calculator"
        },
        {
          "function": "app.prime_data",
          "priority": 4,
          "required": true,
          "description": "Main prime data handler (engine.prime_data)"
        }
      ]
    },
    "app.stop": {
      "description": "Lifecycle: graceful shutdown (save session, cleanup, notify)",
      "handlers": [
        {
          "function": "app.save_session_state",
          "priority": 1,
          "required": true,
          "description": "Save current session state to disk"
        },
        {
          "function": "app.cleanup_resources",
          "priority": 2,
          "required": true,
          "description": "Close file handles, clear caches"
        },
        {
          "function": "app.send_shutdown_notification",
          "priority": 3,
          "required": false,
          "description": "Send shutdown notification to user"
        },
        {
          "function": "app.stop",
          "priority": 4,
          "required": true,
          "description": "Main app stop handler"
        }
      ]
    },
    "engine.tick": {
      "description": "Core: each trading cycle (analyze, decide, execute)",
      "handlers": [
        {
          "function": "engine.update_market_data",
          "priority": 1,
          "required": true,
          "description": "Refresh LTP, calculate indicators"
        },
        {
          "function": "engine.evaluate_entry_conditions",
          "priority": 2,
          "required": true,
          "description": "Check if entry criteria met"
        },
        {
          "function": "engine.evaluate_exit_conditions",
          "priority": 3,
          "required": true,
          "description": "Check if exit criteria met"
        },
        {
          "function": "engine.execute_trade_actions",
          "priority": 4,
          "required": true,
          "description": "Place orders, manage positions"
        },
        {
          "function": "engine.update_portfolio_state",
          "priority": 5,
          "required": true,
          "description": "Update internal position state"
        },
        {
          "function": "engine.tick",
          "priority": 6,
          "required": true,
          "description": "Main tick handler (engine.tick)"
        }
      ]
    },
    "engine.shutdown": {
      "description": "Core: stop the engine (close positions, save state, notify)",
      "handlers": [
        {
          "function": "engine.close_all_positions",
          "priority": 1,
          "required": true,
          "description": "Close all open positions before shutdown"
        },
        {
          "function": "engine.save_engine_state",
          "priority": 2,
          "required": true,
          "description": "Save engine state to session"
        },
        {
          "function": "engine.log_shutdown_reason",
          "priority": 3,
          "required": false,
          "description": "Log why shutdown was triggered"
        },
        {
          "function": "engine.send_shutdown_alert",
          "priority": 4,
          "required": false,
          "description": "Notify user of shutdown"
        },
        {
          "function": "engine.shutdown",
          "priority": 5,
          "required": true,
          "description": "Main engine shutdown handler"
        }
      ]
    },
    "session.hibernate": {
      "description": "Market: pause trading during market close",
      "handlers": [
        {
          "function": "session.pause_strategy",
          "priority": 1,
          "required": true,
          "description": "Pause strategy from taking new positions"
        },
        {
          "function": "session.notify_hibernate",
          "priority": 2,
          "required": false,
          "description": "Notify user of hibernate state"
        },
        {
          "function": "session.hibernate",
          "priority": 3,
          "required": true,
          "description": "Main hibernate handler (session_manager.hibernate)"
        }
      ]
    },
    "session.resume": {
      "description": "Market: resume from hibernate (reconnect, refresh data)",
      "handlers": [
        {
          "function": "session.refresh_market_data",
          "priority": 1,
          "required": true,
          "description": "Refresh LTP and reconnect feeds"
        },
        {
          "function": "session.resume_strategy",
          "priority": 2,
          "required": true,
          "description": "Resume strategy from paused state"
        },
        {
          "function": "session.send_resume_notification",
          "priority": 3,
          "required": false,
          "description": "Notify user that trading resumed"
        }
      ]
    },
    "trade.place_spread": {
      "description": "Trade: place credit spread order",
      "handlers": [
        {
          "function": "trade.validate_margin",
          "priority": 1,
          "required": true,
          "description": "Check sufficient margin available"
        },
        {
          "function": "trade.resolve_contracts",
          "priority": 2,
          "required": true,
          "description": "Resolve option contracts (strike, expiry)"
        },
        {
          "function": "trade.calculate_spread_span",
          "priority": 3,
          "required": true,
          "description": "Calculate span margin for spread"
        },
        {
          "function": "trade.execute_spread_order",
          "priority": 4,
          "required": true,
          "description": "Place the spread order"
        },
        {
          "function": "trade.log_trade",
          "priority": 5,
          "required": true,
          "description": "Log trade details for audit"
        },
        {
          "function": "trade.update_portfolio",
          "priority": 6,
          "required": true,
          "description": "Update internal portfolio state"
        },
        {
          "function": "trade.place_spread",
          "priority": 7,
          "required": true,
          "description": "Main place spread handler (engine.action_logic.place_order)"
        }
      ]
    },
    "trade.place_future_order": {
      "description": "Trade: place futures order",
      "handlers": [
        {
          "function": "trade.validate_margin",
          "priority": 1,
          "required": true,
          "description": "Check sufficient margin available"
        },
        {
          "function": "trade.resolve_future_contract",
          "priority": 2,
          "required": true,
          "description": "Resolve futures contract (expiry month)"
        },
        {
          "function": "trade.calculate_future_margin",
          "priority": 3,
          "required": true,
          "description": "Calculate margin requirement"
        },
        {
          "function": "trade.execute_future_order",
          "priority": 4,
          "required": true,
          "description": "Place the futures order"
        },
        {
          "function": "trade.log_trade",
          "priority": 5,
          "required": true,
          "description": "Log trade details for audit"
        },
        {
          "function": "trade.update_portfolio",
          "priority": 6,
          "required": true,
          "description": "Update internal portfolio state"
        },
        {
          "function": "trade.place_future_order",
          "priority": 7,
          "required": true,
          "description": "Main place future handler (engine.action_logic.place_order)"
        }
      ]
    },
    "trade.square_off_all": {
      "description": "Trade: close all open positions",
      "handlers": [
        {
          "function": "trade.get_open_positions",
          "priority": 1,
          "required": true,
          "description": "Fetch all open positions from broker"
        },
        {
          "function": "trade.validate_square_off",
          "priority": 2,
          "required": true,
          "description": "Validate positions can be closed"
        },
        {
          "function": "trade.execute_square_off_orders",
          "priority": 3,
          "required": true,
          "description": "Place square-off orders"
        },
        {
          "function": "trade.confirm_all_closed",
          "priority": 4,
          "required": true,
          "description": "Verify all positions are closed"
        },
        {
          "function": "trade.calculate_pnl",
          "priority": 5,
          "required": true,
          "description": "Calculate realized P&L"
        },
        {
          "function": "trade.log_square_off",
          "priority": 6,
          "required": true,
          "description": "Log square-off details for audit"
        },
        {
          "function": "trade.square_off_all",
          "priority": 7,
          "required": true,
          "description": "Main square-off handler (engine.action_logic.square_off_all)"
        }
      ]
    },
    "trade.send_alert": {
      "description": "Trade: send notification/alert to user",
      "handlers": [
        {
          "function": "trade.format_alert_message",
          "priority": 1,
          "required": true,
          "description": "Format alert with proper template"
        },
        {
          "function": "trade.send_telegram_alert",
          "priority": 2,
          "required": true,
          "description": "Send via Telegram bot"
        },
        {
          "function": "trade.log_alert",
          "priority": 3,
          "required": true,
          "description": "Log alert to file for audit"
        },
        {
          "function": "trade.send_alert",
          "priority": 4,
          "required": true,
          "description": "Main alert handler (engine.action_logic.send_alert)"
        }
      ]
    }
  },
